# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Environment variables — never commit these
.env*
.env
.env.local
.env.production

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environment
venv/
.venv/
env/

# Testing
/coverage

# Next.js
/.next/
/out/

# Production
/build

# Temp files from file extraction
/tmp/*.anki2
/tmp/*.pdf
/tmp/*.pptx
/tmp/*.docx

# Celery
celerybeat-schedule
celerybeat.pid

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Misc
.DS_Store
Thumbs.db
*.pem

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts
